<cell alignment="left" valignment="top" topline="true" usebox="none">
\begin_inset Text

\begin_layout Plain Layout
Si tenim per exemple el conjunt 
\begin_inset Formula $\left\{ a,b,c,d,e\right\} $
\end_inset

