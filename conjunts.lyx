\begin_inset Text

\begin_layout Plain Layout
I els nombres racionals 
\shape italic
gairebé
\shape default
 serveixen per això.
 Tenen un 
\shape italic
ordre total
\shape default
 igual que tenen els punts d'una recta i també són 
\shape italic
densos
\shape default
 igual que ho són els punts d'una recta.
\end_layout

\end_inset
</cell>
</row>
