</cell>
<cell alignment="left" valignment="top" topline="true" usebox="none">
\begin_inset Text

\begin_layout Plain Layout
És a dir, que cada nombre 
\shape italic
real
\shape default
 (així anomenarem aquest nou conjunt de nombres), el definim com el suprem
 d'un conjunt acotat de nombres racionals.
\end_layout

\end_inset
</cell>
</row>
<row>
<cell alignment="center" valignment="top" topline="true" usebox="none">
\begin_inset Text

\begin_layout Plain Layout
