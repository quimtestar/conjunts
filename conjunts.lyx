<cell alignment="left" valignment="top" topline="true" usebox="none">
\begin_inset Text

\begin_layout Plain Layout
I com que 
\begin_inset Formula $b^{2}$
\end_inset

 és igual a 2 multiplicat per alguna cosa (
\family roman
\series medium
\shape up
\size normal
\emph off
\bar no
\strikeout off
\xout off
