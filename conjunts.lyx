\end_layout

\end_inset


\end_layout

\end_inset
</cell>
<cell alignment="left" valignment="top" topline="true" usebox="none">
\begin_inset Text

\begin_layout Plain Layout
Si enlloc d'anar fila per fila com hem estat fent anem diagonal per diagonal,
 sí que podrem completar la bijecció:
\end_layout

\begin_layout Plain Layout

\end_layout

\begin_layout Plain Layout
\begin_inset Formula 
\[
\begin{array}{ccc}
(0,0) & \shortrightarrow & 0\\
(0,1) & \shortrightarrow & 1\\
(1,0) & \shortrightarrow & 2\\
(0,2) & \shortrightarrow & 3\\
(1,1) & \shortrightarrow & 4\\
(2,0) & \shortrightarrow & 5\\
(0,3) & \shortrightarrow & 6\\
 & \vdots
\end{array}
\]

\end_inset


