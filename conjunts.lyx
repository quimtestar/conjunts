</cell>
<cell alignment="center" valignment="top" topline="true" usebox="none">
\begin_inset Text

\begin_layout Plain Layout
I la multiplicació:
\end_layout

\begin_layout Plain Layout
\begin_inset Formula 
\begin{eqnarray*}
\forall\alpha\textrm{ ordinal, }\alpha·0 & = & 0\\
\forall\alpha\forall\beta\textrm{ ordinals, }\alpha·(\beta+1) & = & \alpha·\beta+\alpha\\
\forall\alpha\textrm{ ordinal }\forall\lambda\textrm{ ordinal límit, }\alpha·\lambda & = & \sup\left\{ \alpha·\beta\mid\beta<\lambda\right\} 
\end{eqnarray*}

\end_inset


\end_layout

\end_inset
</cell>
