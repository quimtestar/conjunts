<cell alignment="left" valignment="top" topline="true" usebox="none">
\begin_inset Text

\begin_layout Plain Layout
L'abstracció ens dóna accés a un coneixement que sense ella seria senzillament
 impossible quan intervenen conjunts mínimament grans.
\end_layout

\end_inset
</cell>
</row>
