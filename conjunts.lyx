<cell alignment="center" valignment="top" topline="true" usebox="none">
\begin_inset Text

\begin_layout Plain Layout
La suma d'ordinals queda definida, doncs, així:
\end_layout

\begin_layout Plain Layout
\begin_inset Formula 
\begin{eqnarray*}
\forall\alpha\textrm{ ordinal, }\alpha+0 & = & \alpha\\
\forall\alpha\forall\beta\textrm{ ordinals, }\alpha+(\beta+1) & = & (\alpha+\beta)+1\\
\forall\alpha\textrm{ ordinal }\forall\lambda\textrm{ ordinal límit, }\alpha+\lambda & = & \sup\left\{ \alpha+\beta\mid\beta<\lambda\right\} 
\end{eqnarray*}

\end_inset


\end_layout

\end_inset
</cell>
</row>
