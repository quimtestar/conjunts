</cell>
<cell alignment="left" valignment="top" topline="true" usebox="none">
\begin_inset Text

\begin_layout Plain Layout
Un 
\shape italic
ordre total
\shape default
 és una relació 
\begin_inset Formula $\leq$
\end_inset

 que donats qualssevol elements 
\begin_inset Formula $a$
\end_inset

, 
\begin_inset Formula $b$
\end_inset

 i 
\begin_inset Formula $c$
\end_inset

 compleix les propietats:
\end_layout

\begin_layout Itemize

\shape italic
reflexivitat
\shape default
: 
\begin_inset Formula $a\leq a$
\end_inset

.
\end_layout

\begin_layout Itemize

\shape italic
transitivitat
\shape default
: si 
\begin_inset Formula $a\leq b$
\end_inset

 i 
\begin_inset Formula $b\leq c$
\end_inset

 aleshores 
\begin_inset Formula $a\leq c$
\end_inset

.
\end_layout

\begin_layout Itemize

\shape italic
antisimetria
\shape default
: si 
\begin_inset Formula $a\leq b$
\end_inset

 i 
\begin_inset Formula $b\leq a$
\end_inset

 aleshores 
\begin_inset Formula $a=b$
\end_inset

.
\end_layout

\begin_layout Itemize

\shape italic
totalitat
\shape default
: 
\begin_inset Formula $a\leq b$
\end_inset

 o 
\begin_inset Formula $b\leq a$
\end_inset

.
\end_layout

\end_inset
</cell>
</row>
<row>
<cell alignment="center" valignment="top" topline="true" usebox="none">
