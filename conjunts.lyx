<cell alignment="left" valignment="top" topline="true" usebox="none">
\begin_inset Text

\begin_layout Plain Layout
De tots els parells 
\begin_inset Formula $a$
\end_inset

 i 
\begin_inset Formula $b$
\end_inset

 que poden representar el mateix racional s'agafa aquell en que els dos
 nombres no tenen cap factor comú i per tant són més petits, la fracció
 irreductible.
\end_layout

\end_inset
</cell>
</row>
