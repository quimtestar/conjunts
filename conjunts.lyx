\end_inset


\end_layout

\end_inset
</cell>
<cell alignment="left" valignment="top" topline="true" usebox="none">
\begin_inset Text

\begin_layout Plain Layout
La suma és una funció molt interessant perquè ens dona la cardinalitat de
 la unió de dos conjunts disjunts a partir només de les seves respectives
 cardinalitats.
\end_layout

\end_inset
</cell>
</row>
<row>
<cell alignment="center" valignment="top" topline="true" usebox="none">
